# ═══════════════════════════════════════════════════════════════
#  .env.example — Пример переменных окружения
#  Скопируйте в .env и заполните реальными значениями
# ═══════════════════════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────────────────────
DB_PASSWORD=your_secure_password_here

# ── Redis ──────────────────────────────────────────────────────
REDIS_PASSWORD=your_redis_password_here

# ── Telegram Bot ───────────────────────────────────────────────
BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZ

# ── API Security ───────────────────────────────────────────────
API_KEY=your_random_api_key_32_chars_min

# ── ЮKassa (опционально) ───────────────────────────────────────
YOOKASSA_SHOP_ID=123456
YOOKASSA_SECRET_KEY=live_your_secret_key
YOOKASSA_RETURN_URL=https://your-domain.com/payment/success

# ── Bothost (для proxy mode) ───────────────────────────────────
BOTHOST_URL=https://nl7.bothost.ru

# ── Cloud.ru VM ────────────────────────────────────────────────
CLOUDRU_VM_IP=your.cloud.ru.vm.ip
